# Variables publiques exposees au navigateur.
# Ces deux valeurs sont necessaires pour activer Supabase Auth et la synchro cloud.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cle strictement serveur. Ne jamais l'exposer cote navigateur, dans du code client,
# dans une capture, ni dans un depot public.
SUPABASE_SERVICE_ROLE_KEY=

# Apple OAuth reste desactive tant que le provider n'est pas configure dans Supabase.
NEXT_PUBLIC_ENABLE_APPLE_OAUTH=false

# URL publique de l'application.
# En local: http://localhost:3000
# En production: remplacer par l'URL Vercel finale, puis redeployer.
NEXT_PUBLIC_APP_URL=http://localhost:3000
